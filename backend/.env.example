PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/krishak_mitra
DB_HOST=localhost
DB_PORT=5432
DB_NAME=krishak_mitra
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads/

# OTP (Simulate - replace with Twilio/MSG91 in production)
OTP_EXPIRY_MINUTES=10
SIMULATE_OTP=true
